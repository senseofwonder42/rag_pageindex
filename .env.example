ENVIRONMENT="local"
LOG_LEVEL="INFO"

# --- Provider selection ---
# "openai_compatible" (default) or "anthropic"
LLM_PROVIDER="openai_compatible"

# --- OpenAI-compatible backend (OpenRouter, vLLM, etc.) ---
# OpenRouter:   LLM_BASE_URL="https://openrouter.ai/api/v1"
# Local vLLM:   LLM_BASE_URL="http://localhost:8000/v1"
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_API_KEY=""
LLM_MODEL="google/gemini-2.5-flash-preview"

# --- Anthropic (only needed when LLM_PROVIDER="anthropic") ---
# ANTHROPIC_API_KEY=""
# LLM_MODEL="claude-sonnet-4-6"

# --- Shared tuning ---
# LLM_MAX_OUTPUT_TOKENS=4096
# LLM_MAX_RETRIES=10
# LLM_RETRY_DELAY_S=1.0
# LLM_TIMEOUT=120.0
